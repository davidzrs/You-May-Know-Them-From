{
  "manifest_version": 3,
  "name": "You May Know Them From",
  "version": "1.0.0",
  "description": "Shows which titles from your MyDramaList library you know an actor, director, writer, or other credited person from.",
  "permissions": ["storage"],
  "host_permissions": ["https://mydramalist.com/*"],
  "content_scripts": [
    {
      "matches": ["https://mydramalist.com/people/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_title": "You May Know Them From",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "ymktf_icon.png",
      "32": "ymktf_icon.png",
      "48": "ymktf_icon.png",
      "128": "ymktf_icon.png"
    }
  },
  "icons": {
    "16": "ymktf_icon.png",
    "32": "ymktf_icon.png",
    "48": "ymktf_icon.png",
    "128": "ymktf_icon.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "youmayknowthemfrom@davidzrs.com"
    }
  }
}