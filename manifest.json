{
  "manifest_version": 3,
  "name": "You May Know Them From (MDL)",
  "version": "1.0.3",
  "description": "Shows which titles from your MyDramaList library you know an actor, director, writer, or other credited person from.",
  "permissions": ["storage"],
  "host_permissions": ["https://mydramalist.com/*"],
  "content_scripts": [
    {
      "matches": ["https://mydramalist.com/people/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_title": "You May Know Them From (MDL)",
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon_128.png"
    }
  },
  "icons": {
    "128": "icon_128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "you-may-know-them-from-mdl@davidzrs",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}